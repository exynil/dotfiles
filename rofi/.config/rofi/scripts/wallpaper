#!/bin/bash

rofi='rofi -theme themes/dmenu.rasi'
wallpapers_dir="$XDG_PICTURES_DIR/wallpapers"
unvided_wallpapers_dir="$XDG_PICTURES_DIR/wallpapers_unviewed"
temp_dir="$wallpapers_dir/temp"
wallpaper="$XDG_PICTURES_DIR/wallpaper.jpg"
current_wallpaper="$(readlink -f "$wallpaper")"
position_file="/tmp/rofi-wallpaper-position"

# –ü–ĺ–ī—Ā—á–ł—ā—č–≤–į–Ķ–ľ –ļ–ĺ–Ľ–ł—á–Ķ—Ā—ā–≤–ĺ –Ĺ–Ķ–Ņ—Ä–ĺ—Ā–ľ–ĺ—ā—Ä–Ķ–Ĺ–Ĺ—č—Ö –ł–∑–ĺ–Ī—Ä–į–∂–Ķ–Ĺ–ł–Ļ
unviewed_count=$(find "$unvided_wallpapers_dir" -type f \( \
    -iname "*.jpg" -o \
    -iname "*.jpeg" -o \
    -iname "*.png" \
\) ! -name "viewed_*" 2>/dev/null | wc -l)

options=(
    "ůįáé | random"
    "ůįÉ≠ | random from latest"
    "ůįąą | random from most viewed"
    "ůįúł | random from toplist"
    "ůįďŹ | random from favorites"
    "ůįÄľ | random from saved"
    "ůįąĖ | next unviewed ($unviewed_count)"
    "ůįÜď | keep wallpaper"
    "ůįÉį | last saved"
    "Ôíé | delete current")

# –ß–ł—ā–į–Ķ–ľ –Ņ–ĺ—Ā–Ľ–Ķ–ī–Ĺ—é—é –Ņ–ĺ–∑–ł—Ü–ł—é –ł–Ľ–ł –ł—Ā–Ņ–ĺ–Ľ—Ć–∑—É–Ķ–ľ 2 –Ņ–ĺ —É–ľ–ĺ–Ľ—á–į–Ĺ–ł—é
if [ -f "$position_file" ]; then
    last_position=$(cat "$position_file")
else
    last_position=2
fi

chosen="$(printf '%s\n' "${options[@]}" | $rofi -p "wallpaper" -dmenu -selected-row "$last_position")"

# –°–ĺ—Ö—Ä–į–Ĺ—Ź–Ķ–ľ –≤—č–Ī—Ä–į–Ĺ–Ĺ—É—é –Ņ–ĺ–∑–ł—Ü–ł—é (–ļ—Ä–ĺ–ľ–Ķ delete current, keep wallpaper –ł last saved)
if [ -n "$chosen" ] &&
    [ "$chosen" != "Ôíé | delete current" ] &&
    [ "$chosen" != "ůįÜď | keep wallpaper" ] &&
    [ "$chosen" != "ůįÉį | last saved" ]; then
    for i in "${!options[@]}"; do
        if [ "${options[$i]}" = "$chosen" ]; then
            echo "$i" > "$position_file"
            break
        fi
    done
fi

if [ -n "$chosen" ] && [ "$chosen" != "ůįÜď | keep wallpaper" ]; then
    if [ "$(pgrep -c "$(basename "$0")")" -gt 1 ]; then
        notify-send "Please wait" && exit 1
    fi
fi

case $chosen in
"ůįáé | random") set-wallpaper "$(swd -l "$temp_dir")" ;;
"ůįÉ≠ | random from latest") set-wallpaper "$(swd -l "$temp_dir" -s date_added)" ;;
"ůįąą | random from most viewed") set-wallpaper "$(swd -l "$temp_dir" -s views)" ;;
"ůįúł | random from toplist") set-wallpaper "$(swd -l "$temp_dir" -s toplist)" ;;
"ůįďŹ | random from favorites") set-wallpaper "$(swd -l "$temp_dir" -s favorites)" ;;
"ůįÄľ | random from saved")
    set-wallpaper "$(find "$wallpapers_dir" -maxdepth 1 -type f | shuf -n 1)"
    ;;
"ůįąĖ | next unviewed"*)
    # –ü–ĺ–Ľ—É—á–į–Ķ–ľ —Ā–Ľ–Ķ–ī—É—é—Č–Ķ–Ķ –Ĺ–Ķ–Ņ—Ä–ĺ—Ā–ľ–ĺ—ā—Ä–Ķ–Ĺ–Ĺ–ĺ–Ķ –ł–∑–ĺ–Ī—Ä–į–∂–Ķ–Ĺ–ł–Ķ
    next_image=$(get-next-image "$unvided_wallpapers_dir")
    if [ -z "$next_image" ]; then
        notify-send "No more unviewed images"
    else
        set-wallpaper "$next_image"
    fi
    ;;
"ůįÜď | keep wallpaper")
    # –°–ĺ–∑–ī–į–Ķ–ľ –≤—Ä–Ķ–ľ–Ķ–Ĺ–Ĺ—É—é –ļ–ĺ–Ņ–ł—é –ī–Ľ—Ź –ĺ–Ī—Ä–į–Ī–ĺ—ā–ļ–ł
    temp_file=$(mktemp)

    trap 'rm -f "$temp_file"' EXIT

    cp "$current_wallpaper" "$temp_file"

    # –£–ī–į–Ľ—Ź–Ķ–ľ –ľ–Ķ—ā–į–ī–į–Ĺ–Ĺ—č–Ķ —á–Ķ—Ä–Ķ–∑ exiftool
    exiftool -all= -overwrite_original "$temp_file" >/dev/null 2>&1

    # –í—č—á–ł—Ā–Ľ—Ź–Ķ–ľ md5sum
    md5_hash=$(md5sum "$temp_file" | cut -d' ' -f1)

    # –ü–ĺ–Ľ—É—á–į–Ķ–ľ —Ä–į—Ā—ą–ł—Ä–Ķ–Ĺ–ł–Ķ —Ą–į–Ļ–Ľ–į
    extension="${current_wallpaper##*.}"

    # –ď–Ķ–Ĺ–Ķ—Ä–ł—Ä—É–Ķ–ľ –ł–ľ—Ź —Ą–į–Ļ–Ľ–į: –ī–į—ā–į-md5sum.—Ä–į—Ā—ą–ł—Ä–Ķ–Ĺ–ł–Ķ
    date_prefix=$(date +%y%m%d-%H%M%S)
    img="${date_prefix}-${md5_hash}.${extension}"

    # –ü—Ä–ĺ–≤–Ķ—Ä—Ź–Ķ–ľ –Ĺ–į–Ľ–ł—á–ł–Ķ –ī—É–Ī–Ľ–ł–ļ–į—ā–į –Ņ–ĺ md5sum –≤ –ł–ľ–Ķ–Ĺ–ł —Ą–į–Ļ–Ľ–į
    if compgen -G "$wallpapers_dir/*-${md5_hash}.${extension}" >/dev/null; then
        notify-send "Image already exists"
    else
        # –°–ĺ—Ö—Ä–į–Ĺ—Ź–Ķ–ľ –ł–∑–ĺ–Ī—Ä–į–∂–Ķ–Ĺ–ł–Ķ —Ā –Ĺ–ĺ–≤—č–ľ –ł–ľ–Ķ–Ĺ–Ķ–ľ
        mv "$temp_file" "$wallpapers_dir/$img" && notify-send "$img saved"
    fi
    ;;
"ůįÉį | last saved")
    set-wallpaper "$(find "$wallpapers_dir" -type f -maxdepth 1 | sort -n | tail -1)"
    ;;
"Ôíé | delete current")
    # –£–ī–į–Ľ—Ź–Ķ–ľ —ā–Ķ–ļ—É—Č–Ķ–Ķ –ł–∑–ĺ–Ī—Ä–į–∂–Ķ–Ĺ–ł–Ķ
    if [ -f "$current_wallpaper" ]; then
        rm "$current_wallpaper"
    fi

    # –£—Ā—ā–į–Ĺ–į–≤–Ľ–ł–≤–į–Ķ–ľ —Ā–Ľ—É—á–į–Ļ–Ĺ–ĺ–Ķ –ł–∑ —Ā–ĺ—Ö—Ä–į–Ĺ–Ķ–Ĺ–Ĺ—č—Ö
    mapfile -t wallpapers < <(find "$wallpapers_dir" -maxdepth 1 -type f)
    set-wallpaper "${wallpapers[$(("$RANDOM" % ${#wallpapers[@]}))]}"
    ;;
esac