#!/bin/bash
set -euo pipefail

# ================= НАСТРОЙКИ =================
DEFAULT_LENGTH=16
DEFAULT_LEVELS=1111

NUMS="23456789"
LOWER="abcdefghijkmnopqrstuvwxyz"
UPPER="ABCDEFGHJKLMNPQRSTUVWXYZ"
SPECIALS="!@#$%^&*()-_=+[]{}:;?"
# ============================================

# Криптостойкое случайное число [0..max)
rand_int() {
    local max=$1
    od -An -N4 -tu4 /dev/urandom | tr -d ' ' | awk "{print \$1 % $max}"
}

# Случайный символ из строки
rand_char() {
    local s="$1"
    echo -n "${s:$(rand_int ${#s}):1}"
}

# Подсчёт включённых типов
count_types() {
    local levels="$1"
    local count=0
    for ((i=0;i<${#levels};i++)); do
        [[ ${levels:i:1} == "1" ]] && ((count++))
    done
    echo "$count"
}

# ================= ГЕНЕРАЦИЯ =================
generate_password() {
    local length="$1"
    local levels="$2"

    local password=()
    local pool=""

    local types_count
    types_count=$(count_types "$levels")

    if (( types_count == 0 )); then
        echo "Ошибка: не выбран ни один тип символов" >&2
        exit 1
    fi

    local min_per_type=$(( length / types_count ))

    add_chars() {
        local charset="$1"
        for ((i=0;i<min_per_type;i++)); do
            password+=("$(rand_char "$charset")")
        done
    }

    [[ ${levels:0:1} == "1" ]] && add_chars "$NUMS"     && pool+="$NUMS"
    [[ ${levels:1:1} == "1" ]] && add_chars "$LOWER"    && pool+="$LOWER"
    [[ ${levels:2:1} == "1" ]] && add_chars "$UPPER"    && pool+="$UPPER"
    [[ ${levels:3:1} == "1" ]] && add_chars "$SPECIALS" && pool+="$SPECIALS"

    # Добиваем остаток (если length % types != 0)
    while (( ${#password[@]} < length )); do
        password+=("$(rand_char "$pool")")
    done

    # Перемешивание (Fisher–Yates)
    for ((i=${#password[@]}-1;i>0;i--)); do
        j=$(rand_int $((i+1)))
        tmp=${password[i]}
        password[i]=${password[j]}
        password[j]=$tmp
    done

    printf '%s' "${password[@]}"
    echo
}

# ================= ЗАПУСК =================
LENGTH=${1:-$DEFAULT_LENGTH}
LEVELS=${2:-$DEFAULT_LEVELS}

generate_password "$LENGTH" "$LEVELS"
